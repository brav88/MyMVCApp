@model List<Ticket>

@{
    ViewData["Title"] = "Product Page";
}


<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Ticket Inventory</h1>
        <p class="text-muted fs-5">
            Detailed list of all products, categories, and technical specifications.
        </p>
        <span class="badge bg-secondary px-3 py-2 fs-6">
            Total Records: @Model.Count()
        </span>
    </div>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover table-striped align-middle mb-0 bg-white">
            <thead class="table-dark text-uppercase fs-7">
                <tr>
                    <th scope="col" class="ps-3">ID</th>
                    <th scope="col">Title</th>
                    <th scope="col">Description</th>
                    <th scope="col">Status</th>
                    <th scope="col">Priority</th>                                 
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center py-4 text-muted">
                            No products found in the database.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var ticket in Model)
                    {
                        <tr onclick="window.location.href='ticket/detail?id=@ticket.Id'" style="cursor: pointer;">
                            <td class="fw-bold text-secondary ps-3">
                                @ticket.Id
                            </td>
                            <td>
                                <span class="fw-semibold text-dark">@ticket.Title</span>
                            </td>
                            <td>
                                <code class="text-muted">@ticket.Description</code>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@ticket.Status</span>
                            </td>
                            <td>
                                <span class="text-secondary">@ticket.Priority</span>
                            </td>                                                                       
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div> 

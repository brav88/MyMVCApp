@model List<Ticket>

@{
    ViewData["Title"] = "Tickets";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Ticket Board</h1>
        <p class="text-muted fs-5">
            Track and manage all active issues, tasks, and requests.
        </p>
        <span class="badge bg-secondary px-3 py-2 fs-6">
            Total Records: @Model.Count()
        </span>
    </div>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover table-striped align-middle mb-0 bg-white">
            <thead class="table-dark text-uppercase fs-7">
                <tr>
                    <th scope="col" class="ps-3">ID</th>
                    <th scope="col">Title</th>
                    <th scope="col">Type</th>
                    <th scope="col" class="text-center">Status</th>
                    <th scope="col" class="text-center">Priority</th>
                    <th scope="col">Assigned To</th>
                    <th scope="col" class="text-end pe-3">Due Date</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            No tickets found.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var ticket in Model)
                    {
                        string statusClass = ticket.Status?.ToLower() switch
                        {
                            "open" or "abierto"                  => "bg-success",
                            "in progress" or "en progreso"       => "bg-warning text-dark",
                            "closed" or "cerrado" or "done"      => "bg-secondary",
                            "blocked" or "bloqueado"             => "bg-danger",
                            _                                    => "bg-light text-dark border"
                        };
                        string priorityClass = ticket.Priority?.ToLower() switch
                        {
                            "high" or "alta"   => "bg-danger",
                            "medium" or "media" => "bg-warning text-dark",
                            "low" or "baja"    => "bg-info text-dark",
                            _                  => "bg-light text-dark border"
                        };

                        <tr onclick="window.location.href='ticket/detail?id=@ticket.Id'" style="cursor: pointer;">
                            <td class="fw-bold text-secondary ps-3">@ticket.Id</td>
                            <td>
                                <span class="fw-semibold text-dark">@ticket.Title</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@ticket.TicketType</span>
                            </td>
                            <td class="text-center">
                                <span class="badge @statusClass">@ticket.Status</span>
                            </td>
                            <td class="text-center">
                                <span class="badge @priorityClass">@ticket.Priority</span>
                            </td>
                            <td class="text-secondary small">
                                @(ticket.AssignedTo ?? "—")
                            </td>
                            <td class="text-end text-secondary small pe-3">
                                @(ticket.DueDate.HasValue ? ticket.DueDate.Value.ToString("dd MMM yyyy") : "—")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

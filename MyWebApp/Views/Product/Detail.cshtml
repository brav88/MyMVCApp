@model ProductDetail

@{
    ViewData["Title"] = "Product Detail";
}

<div class="container py-5">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">Edit Product Details</h3>
            <span class="badge bg-light text-dark fs-6">ID: @Model.ProductId</span>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                <input type="hidden" asp-for="ProductId" />

                <h5 class="text-secondary border-bottom pb-2 mb-3">Basic Information</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="ProductName" class="form-label">Product Name</label>
                        <input asp-for="ProductName" class="form-control" required />
                        <span asp-validation-for="ProductName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="ProductNumber" class="form-label">Product Number</label>
                        <input asp-for="ProductNumber" class="form-control" required />
                        <span asp-validation-for="ProductNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Color" class="form-label">Color</label>
                        <input asp-for="Color" class="form-control" placeholder="N/A" />
                    </div>
                    <div class="col-md-3 d-flex align-items-center mt-4">
                        <div class="form-check form-switch">
                            <input asp-for="MakeFlag" class="form-check-input" type="checkbox" id="MakeFlag">
                            <label class="form-check-label" for="MakeFlag">Manufactured In-House?</label>
                        </div>
                    </div>
                    <div class="col-md-3 d-flex align-items-center mt-4">
                        <div class="form-check form-switch">
                            <input asp-for="FinishedGoodsFlag" class="form-check-input" type="checkbox" id="FinishedGoodsFlag">
                            <label class="form-check-label" for="FinishedGoodsFlag">Finished Good?</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="SafetyStockLevel" class="form-label">Safety Stock Level</label>
                        <input asp-for="SafetyStockLevel" type="number" class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="ReorderPoint" class="form-label">Reorder Point</label>
                        <input asp-for="ReorderPoint" type="number" class="form-control" required />
                    </div>
                </div>

                <h5 class="text-secondary border-bottom pb-2 mb-3">Costs &amp; Inventory</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="CurrentStandardCost" class="form-label">Standard Cost</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="CurrentStandardCost" type="number" step="0.01" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CurrentListPrice" class="form-label">List Price</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="CurrentListPrice" type="number" step="0.01" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="TotalQuantityInStock" class="form-label">Total Quantity In Stock</label>
                        <input asp-for="TotalQuantityInStock" type="number" class="form-control" readonly data-bs-toggle="tooltip" title="Inventory is calculated automatically." />
                        <span class="form-text text-muted">Read-only (Modify via warehouse transactions)</span>
                    </div>
                </div>

                <h5 class="text-secondary border-bottom pb-2 mb-3">Technical Specifications</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-2">
                        <label asp-for="Size" class="form-label">Size</label>
                        <input asp-for="Size" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="SizeUnitMeasureCode" class="form-label">Size UOM</label>
                        <input asp-for="SizeUnitMeasureCode" class="form-control" placeholder="e.g., CM" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Weight" class="form-label">Weight</label>
                        <input asp-for="Weight" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="WeightUnitMeasureCode" class="form-label">Weight UOM</label>
                        <input asp-for="WeightUnitMeasureCode" class="form-control" placeholder="e.g., LB" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DaysToManufacture" class="form-label">Days to Manufacture</label>
                        <input asp-for="DaysToManufacture" type="number" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ProductLine" class="form-label">Product Line</label>
                        <input asp-for="ProductLine" class="form-control" maxlength="2" placeholder="e.g., M" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Class" class="form-label">Class</label>
                        <input asp-for="Class" class="form-control" maxlength="2" placeholder="e.g., H" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Style" class="form-label">Style</label>
                        <input asp-for="Style" class="form-control" maxlength="2" placeholder="e.g., U" />
                    </div>
                </div>

                <h5 class="text-secondary border-bottom pb-2 mb-3">Marketing Dates</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="SellStartDate" class="form-label">Sell Start Date</label>
                        <input asp-for="SellStartDate" type="date" class="form-control" required />
                        <span asp-validation-for="SellStartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SellEndDate" class="form-label">Sell End Date</label>
                        <input asp-for="SellEndDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DiscontinuedDate" class="form-label">Discontinued Date</label>
                        <input asp-for="DiscontinuedDate" type="date" class="form-control" />
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Back to Products
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
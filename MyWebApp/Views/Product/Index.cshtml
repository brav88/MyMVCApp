@model List<Product>

@{
    ViewData["Title"] = "Product Page";
}


<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Product Inventory</h1>
        <p class="text-muted fs-5">
            Detailed list of all products, categories, and technical specifications.
        </p>
        <span class="badge bg-secondary px-3 py-2 fs-6">
            Total Records: @Model.Count()
        </span>
    </div>

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover table-striped align-middle mb-0 bg-white">
            <thead class="table-dark text-uppercase fs-7">
                <tr>
                    <th scope="col" class="ps-3">ID</th>
                    <th scope="col">Product Name</th>
                    <th scope="col">Code Number</th>
                    <th scope="col">Category</th>
                    <th scope="col">Subcategory</th>
                    <th scope="col">Model</th>
                    <th scope="col" class="text-center">Color</th>
                    <th scope="col" class="text-center">Size</th>
                    <th scope="col" class="text-end">Weight</th>
                    <th scope="col" class="text-end pe-3">List Price</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center py-4 text-muted">
                            No products found in the database.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var product in Model)
                    {
                        <tr onclick="window.location.href='product/detail?id=@product.ProductID'" style="cursor: pointer;">
                            <td class="fw-bold text-secondary ps-3">
                                @product.ProductID
                            </td>
                            <td>
                                <span class="fw-semibold text-dark">@product.ProductName</span>
                            </td>
                            <td>
                                <code class="text-muted">@product.ProductNumber</code>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">@product.Category</span>
                            </td>
                            <td>
                                <span class="text-secondary">@product.SubCategory</span>
                            </td>
                            <td>
                                <span class="small text-muted">@(product.Model ?? "—")</span>
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(product.Color))
                                {
                                    <span class="badge bg-secondary text-capitalize">@product.Color</span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-center text-secondary small">
                                @(product.Size ?? "Standard")
                            </td>
                            <td class="text-end text-secondary small">
                                @(product.Weight.HasValue ? $"{product.Weight.Value.ToString("F2")} lbs" : "—")
                            </td>
                            <td class="text-end fw-bold text-success pe-3">
                                @product.ListPrice.ToString("C")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div> 


